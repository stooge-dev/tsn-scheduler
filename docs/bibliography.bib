	pages = {100--111},
	file = {Full Text PDF:C\:\\Users\\tisc06\\Zotero\\storage\\XSSCMUXR\\Hellmanns et al. - 2021 - How to Optimize Joint Routing and Scheduling Models for TSN Using Integer Linear Programming.pdf:application/pdf},
}

