@inproceedings{hellmanns_how_2021,
	address = {New York, NY, USA},
	series = {{RTNS} '21},
	title = {How to {Optimize} {Joint} {Routing} and {Scheduling} {Models} for {TSN} {Using} {Integer} {Linear} {Programming}},
