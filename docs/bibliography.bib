	note = {ISSN: 2835-8414},
	keywords = {Schedules, Scheduling algorithms, Process control, Standardization, Benchmark testing, Systematics, Taxonomy},
	pages = {1--8},
	file = {Full Text PDF:C\:\\Users\\tisc06\\Zotero\\storage\\UISCHSQC\\Schweissguth et al. - 2023 - TSN Scheduler Benchmarking.pdf:application/pdf},
}

