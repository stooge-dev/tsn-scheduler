	keywords = {Delays, joint routing and scheduling, Optimization, Routing, Real-time systems, Scheduling, Deep reinforcement learning (DRL), time-sensitive networking (TSN), graph convolutional network (GCN), Heuristic algorithms, Optimal scheduling, worst case end-to-end latency},
	pages = {23981--23994},
	file = {Full Text PDF:C\:\\Users\\tisc06\\Zotero\\storage\\JHFRVSJU\\Yang et al. - 2022 - Joint Routing and Scheduling Optimization in Time-Sensitive Networks Using Graph-Convolutional-Netwo.pdf:application/pdf},
